DATABASE_URL=postgresql+asyncpg://agent:changeme@db:5432/agent
REDIS_URL=redis://redis:6379/0
OPENAI_API_KEY=sk-your-key-here
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_WEBHOOK_SECRET=any-random-string
DB_PASSWORD=changeme
ENVIRONMENT=production
LOG_LEVEL=INFO

# Optional integrations (plugin disabled if unset)
SERPER_API_KEY=your-serper-key-here

# File reader sandbox (plugin disabled if unset)
# Mount a host directory to /app/files in docker-compose (already configured)
FILE_READER_ROOT=/app/files
FILE_READER_MAX_BYTES=1048576

DEFAULT_TIMEZONE=Asia/Kolkata
